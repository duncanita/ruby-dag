#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/dag"

if ARGV.empty?
  puts "Usage: dag <workflow.yml> [--dry-run] [--no-parallel] [--verbose]"
  exit 1
end

file = ARGV[0]
dry_run = ARGV.include?("--dry-run")
parallel = !ARGV.include?("--no-parallel")
verbose = ARGV.include?("--verbose")

definition = DAG::Loader.from_file(file)

if dry_run
  puts "Workflow: #{file}"
  puts "Nodes: #{definition.size}"
  puts "Execution order:"
  definition.execution_order.each_with_index do |layer, i|
    note = layer.size > 1 ? " (parallel)" : ""
    puts "  Layer #{i}: #{layer.join(", ")}#{note}"
  end
  exit 0
end

on_start = ->(name, _step) { puts "▶ #{name}" if verbose }
on_finish = ->(name, result) {
  status = result.success? ? "✓" : "✗"
  detail = result.failure? ? " — #{result.error}" : ""
  puts "  #{status} #{name}#{detail}"
}

result = DAG::Runner.new(definition.graph, definition.registry,
  parallel: parallel, on_node_start: on_start, on_node_finish: on_finish).call

if result.success?
  puts "\n✓ Workflow completed (#{definition.size} nodes)"
else
  $stderr.puts "\n✗ Failed at '#{result.error[:failed_node]}': #{result.error[:error]}"
  exit 1
end
