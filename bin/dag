#!/usr/bin/env ruby
# frozen_string_literal: true

require "dag"

USAGE = <<~TXT
  Usage: dag <workflow.yml> [options]

  Run a YAML-defined DAG workflow.

  Options:
    --dry-run         Print the execution plan and exit without running steps.
    --no-parallel     Force sequential execution (default is :threads).
    --verbose         Print each step as it starts.
    -h, --help        Show this help.

  Exit codes:
    0   Workflow completed successfully.
    1   Workflow failed (a step returned Failure or the workflow timed out).
    2   Bad usage / failed to load the workflow file.
TXT

if ARGV.empty? || ARGV.include?("-h") || ARGV.include?("--help")
  puts USAGE
  exit(ARGV.empty? ? 2 : 0)
end

file = ARGV[0]
dry_run = ARGV.include?("--dry-run")
parallel = !ARGV.include?("--no-parallel")
verbose = ARGV.include?("--verbose")

begin
  definition = DAG::Workflow::Loader.from_file(file)
rescue => e
  warn "dag: failed to load #{file}: #{e.class}: #{e.message}"
  exit 2
end

if dry_run
  puts "Workflow: #{file}"
  puts "Nodes:    #{definition.size}"
  puts "Execution order:"
  definition.execution_order.each_with_index do |layer, i|
    note = (layer.size > 1) ? " (parallel)" : ""
    puts "  Layer #{i}: #{layer.join(", ")}#{note}"
  end
  exit 0
end

on_start = ->(name, _step) { puts "▶ #{name}" if verbose }
on_finish = ->(name, result) {
  status = result.success? ? "✓" : "✗"
  detail = result.failure? ? " — #{result.error}" : ""
  puts "  #{status} #{name}#{detail}"
}

result = DAG::Workflow::Runner.new(definition.graph, definition.registry,
  parallel: parallel, on_step_start: on_start, on_step_finish: on_finish).call

if result.success?
  trace = result.value[:trace]
  puts "\n✓ Workflow completed (#{definition.size} nodes, #{trace.size} steps traced)"
  exit 0
else
  failure = result.error[:error]
  warn "\n✗ Failed at '#{failure[:failed_node]}': #{failure[:step_error]}"
  exit 1
end
